# ============================================================
#  Comunidade FGZ — variáveis de ambiente
#  Copie este arquivo para ".env.local" e preencha os valores.
# ============================================================

# Link de convite da COMUNIDADE OFICIAL do WhatsApp do Fabricio.
# Ex.: https://chat.whatsapp.com/XXXXXXXXXXXXXXX
# (público — vai para o navegador do visitante)
NEXT_PUBLIC_WHATSAPP_URL=

# URL do Web App do Google Apps Script que grava os leads na planilha.
# Termina em /exec — gerada quando você publica o script
# (ver google-apps-script/SETUP-GOOGLE-SHEETS.md).
# (secreta — só o servidor usa)
GOOGLE_SHEETS_WEBHOOK_URL=
